# AgroAdvisor local configuration template.
# Copy to .env for local development and replace placeholders with real secrets.

# Core backend secrets
GOOGLE_API_KEY=replace-with-google-api-key
PINECONE_API_KEY=replace-with-pinecone-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret

# Current retrieval defaults
EMBEDDING_MODEL_PATH=thenlper/gte-base
PINECONE_INDEX_NAME=agroar-prod-gte-v2
RERANK_ENABLED=0

# Frontend / deployment
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-supabase-anon-key

# LLM provider chain
LLM_PRIMARY=groq
GROQ_API_KEY=replace-with-groq-api-key
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant
DEEPINFRA_API_KEY=replace-with-deepinfra-api-key
DEEPINFRA_MODEL=meta-llama/Llama-3.3-70B-Instruct
LOCAL_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Cache / rate limiting / observability
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SENTRY_DSN=

# Admin and test accounts
ADMIN_USER_IDS=
TEST_EMAIL=
TEST_PASSWORD=
ADMIN_EMAIL=
ADMIN_PASSWORD=

# NOAA contact used in weather.gov User-Agent
NOAA_CONTACT_EMAIL=you@example.com

# Eval controls
RUN_ANSWER_EVAL=0
ANSWER_EVAL_SAMPLE=20
EVAL_WRITE_TO_DB=0
